# Paste these into Railway → HealthCare service → Variables
# Replace CHANGE_ME values. Link MySQL via ${{MySQL.MYSQL_URL}} for DATABASE_URL.

APP_ENV=prod
APP_DEBUG=0
APP_SECRET=CHANGE_ME

DATABASE_URL=${{MySQL.MYSQL_URL}}

DEFAULT_URI=https://YOUR-SERVICE.up.railway.app

JWT_PASSPHRASE=CHANGE_ME
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem

CORS_ALLOW_ORIGIN=^https?://.*$

MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0

MAILER_DSN=
MAILER_FROM_ADDRESS=
MAILER_FROM_NAME=Health Care Clinic
CONTACT_NOTIFY_EMAIL=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
