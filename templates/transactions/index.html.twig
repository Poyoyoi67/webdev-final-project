{% extends 'base.html.twig' %}

{% block title %}Transactions{% endblock %}

{% block body %}
    <style>
        :root {
            --primary-blue: #000080;
            --accent-turquoise: #40E0D0;
            --light-gray: #f8f9fa;
        }
        h1 { text-align: center; margin-bottom: 1.5rem; }
        table { width: 100%; border-collapse: collapse; background: #fff; box-shadow: 0 8px 24px rgba(3,3,63,0.12); border-radius: 12px; overflow: hidden; }
        th, td { padding: 0.9rem; border-bottom: 1px solid var(--light-gray); }
        thead th { background: linear-gradient(135deg, var(--primary-blue), var(--accent-turquoise)); color: #fff; text-align: left; }
    </style>

    <h1>Transactions</h1>

    {% if payments is empty %}
        <p>No payments recorded yet.</p>
    {% else %}
        <table>
            <thead>
            <tr>
                <th>Paid At</th>
                <th>Appointment</th>
                <th>Patient</th>
                <th>Amount</th>
                <th>Change</th>
                <th>Method</th>
                <th>Appt Status</th>
                <th>Actions</th>
            </tr>
            </thead>
            <tbody>
            {% for payment in payments %}
                <tr>
                    <td>{{ payment.paidAt|date('Y-m-d H:i') }}</td>
                    <td>#{{ payment.appointment.id }}</td>
                    <td>{{ payment.appointment.patientName }}</td>
                    <td>{{ payment.amount|number_format(2, '.', ',') }}</td>
                    <td>{{ payment.changeAmount is not null ? payment.changeAmount|number_format(2, '.', ',') : '—' }}</td>
                    <td>{{ payment.paymentMethod ? payment.paymentMethod|capitalize : '—' }}</td>
                    <td>{{ payment.appointment.status ?? '—' }}</td>
                    <td>
                        <a href="{{ path('app_transactions_manage', {id: payment.appointment.id}) }}">View / Edit</a>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    {% endif %}
{% endblock %}


