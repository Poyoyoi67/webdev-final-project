{% extends 'base.html.twig' %}

{% block title %}Home — Health Center{% endblock %}

{% block body %}
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');

        .dash-wrap {
            font-family: 'Inter', 'Segoe UI', system-ui, sans-serif;
            max-width: 1200px;
            margin: 0 auto;
        }

        .dash-hero {
            background: linear-gradient(135deg, #0f3c74 0%, #0b2a52 55%, #124a8f 100%);
            color: #fff;
            border-radius: 16px;
            padding: 1.75rem 1.5rem 1.5rem;
            margin-bottom: 1.75rem;
            box-shadow: 0 12px 32px rgba(15, 60, 116, 0.25);
            position: relative;
            overflow: hidden;
        }
        .dash-hero::after {
            content: '';
            position: absolute;
            top: -40%;
            right: -10%;
            width: 45%;
            height: 180%;
            background: radial-gradient(circle, rgba(36, 184, 181, 0.25) 0%, transparent 70%);
            pointer-events: none;
        }
        .dash-hero h1 {
            margin: 0 0 0.35rem;
            font-size: clamp(1.35rem, 2.5vw, 1.65rem);
            font-weight: 700;
            letter-spacing: -0.02em;
            position: relative;
            z-index: 1;
        }
        .dash-hero p {
            margin: 0;
            color: #c8daf5;
            font-size: 0.92rem;
            position: relative;
            z-index: 1;
        }
        .dash-hero .role-chip {
            display: inline-block;
            margin-top: 0.75rem;
            padding: 0.35rem 0.75rem;
            border-radius: 999px;
            background: rgba(36, 184, 181, 0.25);
            border: 1px solid rgba(36, 184, 181, 0.45);
            font-size: 0.72rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            color: #a5f0ee;
        }

        .dash-stats {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1rem;
            margin-bottom: 1.75rem;
        }
        .stat-card {
            background: #fff;
            border-radius: 14px;
            padding: 1.15rem 1.2rem;
            border: 1px solid #e2e8f0;
            box-shadow: 0 4px 18px rgba(15, 60, 116, 0.06);
            position: relative;
            transition: transform 0.15s ease, box-shadow 0.15s ease;
        }
        .stat-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 28px rgba(15, 60, 116, 0.1);
        }
        .stat-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 1rem;
            right: 1rem;
            height: 3px;
            border-radius: 0 0 4px 4px;
            background: linear-gradient(90deg, #24b8b5, #0f3c74);
        }
        .stat-card .label {
            font-size: 0.78rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: #64748b;
            margin-bottom: 0.35rem;
        }
        .stat-card .value {
            font-size: 1.85rem;
            font-weight: 800;
            color: #0f172a;
            letter-spacing: -0.03em;
            line-height: 1.1;
        }

        .dash-panel {
            background: #fff;
            border-radius: 14px;
            border: 1px solid #e2e8f0;
            box-shadow: 0 4px 18px rgba(15, 60, 116, 0.06);
            margin-bottom: 1.5rem;
            overflow: hidden;
        }
        .dash-panel-head {
            padding: 1rem 1.25rem;
            border-bottom: 1px solid #f1f5f9;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 0.5rem;
        }
        .dash-panel-head h2 {
            margin: 0;
            font-size: 1.05rem;
            font-weight: 700;
            color: #0f3c74;
        }

        .status-mini-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
            gap: 0.75rem;
            padding: 1.25rem;
        }
        .status-pill {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            padding: 0.85rem 1rem;
            text-align: center;
        }
        .status-pill .name {
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: capitalize;
            color: #64748b;
            margin-bottom: 0.25rem;
        }
        .status-pill .num {
            font-size: 1.35rem;
            font-weight: 800;
            color: #0f3c74;
        }

        .dash-table-wrap {
            padding: 0 1.25rem 1.25rem;
            overflow-x: auto;
        }
        .dash-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.88rem;
        }
        .dash-table th {
            text-align: left;
            padding: 0.65rem 0.75rem;
            background: #f1f5f9;
            color: #475569;
            font-weight: 600;
            font-size: 0.72rem;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            border-bottom: 1px solid #e2e8f0;
        }
        .dash-table td {
            padding: 0.75rem;
            border-bottom: 1px solid #f1f5f9;
            color: #334155;
        }
        .dash-table tbody tr:hover td {
            background: #f8fafc;
        }
        .badge-status {
            display: inline-block;
            padding: 0.2rem 0.55rem;
            border-radius: 999px;
            font-size: 0.72rem;
            font-weight: 600;
            text-transform: capitalize;
        }
        .badge-generic { background: #f1f5f9; color: #475569; }
        .badge-confirmed { background: #dbeafe; color: #1e40af; }
        .badge-finished { background: #d1fae5; color: #065f46; }
        .badge-cancelled { background: #fee2e2; color: #991b1b; }

        .empty-state {
            padding: 2rem 1.25rem;
            text-align: center;
            color: #64748b;
            font-size: 0.92rem;
        }

        .live-updated {
            animation: liveFlash 0.9s ease;
        }
        @keyframes liveFlash {
            0% { box-shadow: 0 0 0 0 rgba(36, 184, 181, 0.55); }
            70% { box-shadow: 0 0 0 8px rgba(36, 184, 181, 0); }
            100% { box-shadow: none; }
        }

        .live-sync-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            margin-top: 0.65rem;
            padding: 0.3rem 0.7rem;
            border-radius: 999px;
            font-size: 0.72rem;
            font-weight: 600;
            color: #94a3b8;
            background: rgba(15, 23, 42, 0.35);
            border: 1px solid rgba(148, 163, 184, 0.35);
        }
        .live-sync-badge::before {
            content: '';
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #64748b;
        }
        .live-sync-badge--on {
            color: #a5f0ee;
            border-color: rgba(36, 184, 181, 0.55);
        }
        .live-sync-badge--on::before {
            background: #24b8b5;
            box-shadow: 0 0 0 3px rgba(36, 184, 181, 0.35);
            animation: livePulse 1.6s ease-in-out infinite;
        }
        @keyframes livePulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.45; }
        }
    </style>

    <div class="dash-wrap" id="staff-dashboard-live">
        <div class="dash-hero">
            <h1>Welcome back{% if app.user %}<span style="font-weight:500;opacity:.9">, {{ app.user.userIdentifier }}</span>{% endif %}</h1>
            <p>Overview of appointments, capacity, and what is coming up next at the clinic.</p>
            {% if app.user %}
                {% set roles = app.user.roles %}
                <span class="role-chip">
                    {% if 'ROLE_ADMIN' in roles %}Administrator{% elseif 'ROLE_STAFF' in roles %}Staff{% else %}Patient{% endif %}
                </span>
            {% endif %}
            <span id="live-sync-badge" class="live-sync-badge" hidden>Live — connecting…</span>
        </div>

        <div class="dash-stats">
            <div class="stat-card">
                <div class="label">Appointments</div>
                <div class="value" data-stat="appointments">{{ totalAppointments }}</div>
            </div>
            <div class="stat-card">
                <div class="label">Doctors</div>
                <div class="value" data-stat="doctors">{{ totalDoctors }}</div>
            </div>
            <div class="stat-card">
                <div class="label">Services</div>
                <div class="value" data-stat="services">{{ totalServices }}</div>
            </div>
            <div class="stat-card">
                <div class="label">Payments</div>
                <div class="value" data-stat="payments">{{ totalPayments }}</div>
            </div>
        </div>

        <div class="dash-panel">
            <div class="dash-panel-head">
                <h2>Appointments by status</h2>
            </div>
            <div class="status-mini-grid" id="status-counts-grid">
                {% for status in trackedStatuses %}
                    <div class="status-pill" data-status="{{ status }}">
                        <div class="name">{{ status }}</div>
                        <div class="num">{{ statusCounts[status]|default(0) }}</div>
                    </div>
                {% endfor %}
            </div>
        </div>

        <div class="dash-panel">
            <div class="dash-panel-head">
                <h2>Upcoming appointments</h2>
            </div>
            <div id="upcoming-appointments-live">
            {% if upcoming is empty %}
                <div class="empty-state">No upcoming appointments from today onward.</div>
            {% else %}
                <div class="dash-table-wrap">
                    <table class="dash-table">
                        <thead>
                            <tr>
                                <th>Date &amp; time</th>
                                <th>Patient</th>
                                <th>Doctor</th>
                                <th>Service</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for appt in upcoming %}
                                <tr data-appt-id="{{ appt.id }}">
                                    <td>{{ appt.appointmentDate|date('M j, Y · g:i A') }}</td>
                                    <td>{{ appt.patientName }}</td>
                                    <td>{{ appt.doctor ? appt.doctor.name : '—' }}</td>
                                    <td>{{ appt.service ? appt.service.name : '—' }}</td>
                                    <td>
                                        {% set s = appt.status|default('')|lower|replace({' ': '-'}) %}
                                        <span class="badge-status {% if s in ['confirmed', 'finished', 'cancelled'] %}badge-{{ s }}{% else %}badge-generic{% endif %}">{{ appt.status }}</span>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
            </div>
        </div>
    </div>

    <script src="/js/realtime-appointments.js?v=2"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            if (!window.HealthCareRealtime) return;
            HealthCareRealtime.initStaffDashboard(
                '{{ path('app_realtime_appointments_version') }}',
                '{{ path('app_realtime_staff_dashboard') }}'
            );
        });
    </script>
{% endblock %}
