{% extends 'base.html.twig' %}

{% block title %}Home — Health Center{% endblock %}

{% block header %}Services &amp; care team{% endblock %}

{% block body %}
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');

        .patient-dash {
            font-family: 'Inter', 'Segoe UI', system-ui, sans-serif;
            max-width: 1100px;
            margin: 0 auto;
        }

        .patient-hero {
            background: linear-gradient(135deg, #0f3c74 0%, #0b2a52 55%, #124a8f 100%);
            color: #ffffff;
            border-radius: 16px;
            padding: 1.75rem 1.5rem 1.5rem;
            margin-bottom: 1.75rem;
            box-shadow: 0 12px 32px rgba(15, 60, 116, 0.25);
            position: relative;
            overflow: hidden;
        }
        .patient-hero::after {
            content: '';
            position: absolute;
            top: -40%;
            right: -10%;
            width: 45%;
            height: 180%;
            background: radial-gradient(circle, rgba(36, 184, 181, 0.28) 0%, transparent 70%);
            pointer-events: none;
        }
        .patient-hero h1 {
            margin: 0 0 0.5rem;
            font-size: clamp(1.35rem, 2.5vw, 1.65rem);
            font-weight: 700;
            letter-spacing: -0.02em;
            position: relative;
            z-index: 1;
            color: #ffffff;
        }
        .patient-hero .sub {
            margin: 0;
            color: #c8e4ff;
            font-size: 0.95rem;
            line-height: 1.45;
            position: relative;
            z-index: 1;
            max-width: 36rem;
        }
        .patient-hero .date-note {
            display: inline-block;
            margin-top: 0.85rem;
            padding: 0.35rem 0.75rem;
            border-radius: 999px;
            background: rgba(36, 184, 181, 0.22);
            border: 1px solid rgba(165, 240, 238, 0.45);
            font-size: 0.72rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            color: #d4faf8;
            position: relative;
            z-index: 1;
        }

        .section {
            margin-bottom: 2rem;
        }
        .section-head {
            display: flex;
            align-items: baseline;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 0.5rem 1rem;
            margin-bottom: 1rem;
        }
        .section-head h2 {
            margin: 0;
            font-size: 1.15rem;
            font-weight: 700;
            color: #0f3c74;
        }
        .section-head p {
            margin: 0;
            font-size: 0.88rem;
            color: #64748b;
        }

        .service-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
            gap: 1rem;
        }
        .service-card {
            background: #fff;
            border-radius: 14px;
            border: 1px solid #e2e8f0;
            padding: 1.15rem 1.2rem;
            box-shadow: 0 4px 18px rgba(15, 60, 116, 0.06);
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
            transition: transform 0.15s ease, box-shadow 0.15s ease;
        }
        .service-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 28px rgba(15, 60, 116, 0.1);
        }
        .service-card h3 {
            margin: 0;
            font-size: 1.05rem;
            font-weight: 700;
            color: #0f172a;
        }
        .service-meta {
            font-size: 0.82rem;
            color: #64748b;
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem 1rem;
        }
        .service-meta strong {
            color: #0f3c74;
        }
        .service-card .blurb {
            margin: 0;
            font-size: 0.88rem;
            color: #475569;
            line-height: 1.45;
            flex: 1;
        }
        .service-card a.more {
            align-self: flex-start;
            margin-top: 0.25rem;
            font-size: 0.86rem;
            font-weight: 600;
            color: #0f3c74;
            text-decoration: none;
        }
        .service-card a.more:hover {
            text-decoration: underline;
            color: #24b8b5;
        }

        .doctor-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 1rem;
        }
        .doctor-card {
            background: #fff;
            border-radius: 14px;
            border: 1px solid #e2e8f0;
            padding: 1.1rem 1.15rem;
            box-shadow: 0 4px 18px rgba(15, 60, 116, 0.06);
            display: flex;
            gap: 1rem;
            align-items: flex-start;
        }
        .doctor-avatar {
            width: 56px;
            height: 56px;
            border-radius: 50%;
            background: linear-gradient(145deg, #e0f2fe, #ccfbf1);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 1.1rem;
            color: #0f3c74;
            flex-shrink: 0;
        }
        .doctor-body {
            min-width: 0;
            flex: 1;
        }
        .doctor-name-row {
            display: flex;
            align-items: center;
            gap: 0.45rem;
            flex-wrap: wrap;
        }
        .doctor-body h3 {
            margin: 0;
            font-size: 1rem;
            font-weight: 700;
            color: #0f172a;
        }
        .presence {
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            font-size: 0.78rem;
            font-weight: 600;
            color: #64748b;
        }
        .presence-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            flex-shrink: 0;
        }
        .presence-dot--on {
            background: #22c55e;
            box-shadow: 0 0 0 2px rgba(34, 197, 94, 0.35);
        }
        .presence-dot--off {
            background: #cbd5e1;
            box-shadow: none;
        }
        .presence-label--on { color: #15803d; }
        .presence-label--off { color: #64748b; }

        .doctor-spec {
            margin: 0.25rem 0 0;
            font-size: 0.86rem;
            color: #475569;
        }
        .doctor-actions {
            margin-top: 0.65rem;
        }
        .doctor-actions a {
            font-size: 0.86rem;
            font-weight: 600;
            color: #0f3c74;
            text-decoration: none;
        }
        .doctor-actions a:hover {
            color: #24b8b5;
            text-decoration: underline;
        }

        .empty-hint {
            background: #f8fafc;
            border: 1px dashed #cbd5e1;
            border-radius: 12px;
            padding: 1.25rem;
            color: #64748b;
            font-size: 0.92rem;
            text-align: center;
        }
    </style>

    <div class="patient-dash">
        <div class="patient-hero">
            <h1>
                {% if app.user %}
                    Hi, {{ app.user.userIdentifier }}
                {% else %}
                    Welcome
                {% endif %}
            </h1>
            <p class="sub">Explore what we offer and who you may see. Doctor availability follows your clinic calendar &mdash; the green dot means they are marked available for <strong style="color:#e0f2fe;">today</strong>.</p>
            <span class="date-note">Availability for {{ availabilityLabelDate|date('l, M j, Y') }}</span>
        </div>

        <section class="section" aria-labelledby="services-heading">
            <div class="section-head">
                <h2 id="services-heading">Our services</h2>
                <p>Care options, pricing, and visit length where listed.</p>
            </div>
            {% if services is empty %}
                <div class="empty-hint">No services are listed yet. Check back soon.</div>
            {% else %}
                <div class="service-grid">
                    {% for service in services %}
                        <article class="service-card">
                            <h3>{{ service.name }}</h3>
                            <div class="service-meta">
                                <span><strong>{{ service.price }}</strong> fee</span>
                                {% if service.duration %}
                                    <span><strong>{{ service.duration }}</strong> min</span>
                                {% endif %}
                            </div>
                            {% if service.text %}
                                <p class="blurb">{{ service.text }}</p>
                            {% endif %}
                            <a class="more" href="{{ path('app_service_show', {id: service.id}) }}">View details →</a>
                        </article>
                    {% endfor %}
                </div>
            {% endif %}
        </section>

        <section class="section" aria-labelledby="doctors-heading">
            <div class="section-head">
                <h2 id="doctors-heading">Our doctors</h2>
                <p><span class="presence-dot presence-dot--on" aria-hidden="true" style="vertical-align:-2px;margin-right:4px;"></span> Available today &middot; <span class="presence-dot presence-dot--off" aria-hidden="true" style="vertical-align:-2px;margin-right:4px;"></span> Not on today&rsquo;s schedule</p>
            </div>
            {% if doctors is empty %}
                <div class="empty-hint">No doctors are listed yet.</div>
            {% else %}
                <div class="doctor-grid">
                    {% for doctor in doctors %}
                        {% set isAvailableToday = doctor.id in availableDoctorIds %}
                        <article class="doctor-card">
                            <div class="doctor-avatar" aria-hidden="true">{{ doctor.name|slice(0, 1)|upper }}</div>
                            <div class="doctor-body">
                                <div class="doctor-name-row">
                                    <h3>{{ doctor.name }}</h3>
                                    <span class="presence" title="{{ isAvailableToday ? 'Available today per clinic calendar' : 'No available slot marked for today' }}">
                                        <span class="presence-dot {{ isAvailableToday ? 'presence-dot--on' : 'presence-dot--off' }}" aria-hidden="true"></span>
                                        <span class="{{ isAvailableToday ? 'presence-label--on' : 'presence-label--off' }}">{{ isAvailableToday ? 'Available today' : 'Not today' }}</span>
                                    </span>
                                </div>
                                <p class="doctor-spec">{{ doctor.specialization }}</p>
                                <div class="doctor-actions">
                                    <a href="{{ path('app_doctor_show', {id: doctor.id}) }}">View profile →</a>
                                </div>
                            </div>
                        </article>
                    {% endfor %}
                </div>
            {% endif %}
        </section>
    </div>

    <script>
        (function () {
            if (!window.EventSource) return;

            let reloadQueued = false;
            const source = new EventSource('{{ path('app_realtime_appointments_stream') }}');

            const queueReload = () => {
                if (reloadQueued) return;
                reloadQueued = true;
                setTimeout(() => window.location.reload(), 600);
            };

            source.addEventListener('appointment-update', queueReload);
            source.onerror = () => {
                // Auto-reconnect happens by default.
            };
        })();
    </script>
{% endblock %}
