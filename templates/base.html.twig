<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Admin Panel{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚙️</text></svg>">

        {% block stylesheets %}
            {{ encore_entry_link_tags('app') }}
            <link rel="stylesheet" href="{{ asset('css/style.css') }}">
            <style>
                :root {
                    --primary-blue: #000080;
                    --accent-turquoise: #40E0D0;
                    --dark-navy: #03033f;
                    --white: #ffffff;
                    --text-dark: #2c3e50;
                    --light-gray: #f9f9f9;
                }

                * {
                    box-sizing: border-box;
                }

                body {
                    margin: 0;
                    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                    background: var(--light-gray);
                    color: var(--text-dark);
                    display: flex;
                    height: 100vh;
                    overflow: hidden;
                }

                /* Sidebar */
                .sidebar {
                    width: 260px;
                    background: var(--white);
                    color: var(--primary-blue);
                    display: flex;
                    flex-direction: column;
                    align-items: center;
                    padding: 1.2rem 0;
                    box-shadow: 4px 0 12px rgba(0,0,0,0.1);
                    position: relative;
                    overflow-y: auto;
                    scrollbar-width: none; /* Firefox */
                }

                .sidebar::-webkit-scrollbar {
                    display: none; /* Chrome, Safari */
                }

                /* Logo + Brand */
                .sidebar .brand {
                    display: flex;
                    flex-direction: column;
                    align-items: center;
                    padding: 16px 16px 10px 16px;
                    width: 88%;
                    margin-top: -10px;
                    margin-bottom: 1.5rem;
                }

                .sidebar .brand .logo-container {
                    padding: 10px;
                    margin-bottom: 10px;
                    width: 100%;
                    display: flex;
                    justify-content: center;
                    align-items: center;
                }

                .sidebar .brand img {
                    width: 120px;
                    height: auto;
                    display: block;
                }

                .sidebar .brand h1 {
                    font-size: 1.2rem;
                    color: var(--primary-blue);
                    font-weight: 700;
                    margin: 0;
                    text-align: center;
                    letter-spacing: 0.5px;
                }

                /* Sidebar Navigation */
                .sidebar nav {
                    display: flex;
                    flex-direction: column;
                    width: 100%;
                    gap: 4px;
                    padding: 0 12px;
                }

                .sidebar nav a {
                    color: var(--primary-blue);
                    text-decoration: none;
                    padding: 12px 20px;
                    font-weight: 500;
                    font-size: 0.95rem;
                    border-left: 4px solid transparent;
                    border-radius: 0 8px 8px 0;
                    transition: all 0.3s ease;
                    display: block;
                }

                .sidebar nav a:hover {
                    background: rgba(0, 0, 128, 0.1);
                    border-left-color: var(--accent-turquoise);
                    padding-left: 28px;
                }

                .sidebar nav a.active {
                    background: rgba(0, 0, 128, 0.15);
                    border-left-color: var(--accent-turquoise);
                    font-weight: 600;
                    color: var(--primary-blue);
                }

                .sidebar nav a[href*="logout"]:hover {
                    background: rgba(220, 38, 38, 0.1);
                    border-left-color: #dc2626;
                    color: #dc2626;
                }

                /* Main Content */
                .main-content {
                    flex: 1;
                    display: flex;
                    flex-direction: column;
                    min-height: 100vh;
                }

                /* Header */
                header {
                    background: linear-gradient(135deg, var(--accent-turquoise) 0%, var(--primary-blue) 100%);
                    color: var(--white);
                    padding: 1.2rem 2rem;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    box-shadow: 0 3px 12px rgba(0,0,0,0.12);
                    position: relative;
                    z-index: 100;
                }

                .header-title {
                    margin: 0;
                    font-size: 1.6rem;
                    font-weight: 700;
                    text-align: center;
                }

                main {
                    flex: 1;
                    padding: 2rem;
                    overflow-y: auto;
                    background: var(--light-gray);
                }

                footer {
                    background: var(--dark-navy);
                    color: var(--white);
                    text-align: center;
                    padding: 1.2rem;
                    font-size: 0.9rem;
                    margin-top: auto;
                    box-shadow: 0 -2px 8px rgba(0,0,0,0.1);
                }

            </style>
        {% endblock %}
    </head>

    <body>
        <!-- Sidebar -->
        <aside class="sidebar" id="sidebar">
            <div class="brand">
                <div class="logo-container">
                    <img src="{{ asset('images/backgroynd.png') }}" alt="Health Care Logo">
                </div>
                <h1>{% if is_granted('ROLE_ADMIN') %}Admin Panel{% else %}Staff Panel{% endif %}</h1>
            </div>

            <nav>
                <a href="{{ path('app_dashboard') }}"
                   class="{{ app.request.attributes.get('_route') starts with 'app_dashboard' ? 'active' : '' }}">
                    Dashboard
                </a>

                <a href="{{ path('app_service_index') }}"
                   class="{{ app.request.attributes.get('_route') starts with 'app_service' ? 'active' : '' }}">
                    Manage Services
                </a>

                <a href="{{ path('app_doctor_index') }}"
                   class="{{ app.request.attributes.get('_route') starts with 'app_doctor' ? 'active' : '' }}">
                    Manage Doctors
                </a>

                <a href="{{ path('app_appointment_index') }}"
                   class="{{ app.request.attributes.get('_route') starts with 'app_appointment' ? 'active' : '' }}">
                    Appointments
                </a>

                <a href="{{ path('app_report_index') }}"
                   class="{{ app.request.attributes.get('_route') starts with 'app_report' ? 'active' : '' }}">
                    Reports
                </a>

                <a href="{{ path('app_availability_index') }}"
                   class="{{ app.request.attributes.get('_route') starts with 'app_availability' ? 'active' : '' }}">
                    Calendar
                </a>

                {% if is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('app_transactions_index') }}"
                       class="{{ app.request.attributes.get('_route') starts with 'app_transactions' ? 'active' : '' }}">
                        Transactions
                    </a>

                    <a href="{{ path('app_activity_log_index') }}"
                       class="{{ app.request.attributes.get('_route') starts with 'app_activity_log' ? 'active' : '' }}">
                        Activity Log
                    </a>
                {% endif %}

                {% if is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('app_user_index') }}"
                       class="{{ app.request.attributes.get('_route') starts with 'app_user' ? 'active' : '' }}">
                        Users
                    </a>
                {% endif %}

                <a href="{{ path('app_profile') }}"
                   class="{{ app.request.attributes.get('_route') starts with 'app_profile' ? 'active' : '' }}">
                    Profile
                </a>

                <a href="{{ path('app_location_index') }}"
                   class="{{ app.request.attributes.get('_route') starts with 'app_location' ? 'active' : '' }}">
                    Location
                </a>

                <a href="{{ path('app_about') }}"
                   class="{{ app.request.attributes.get('_route') starts with 'app_about' ? 'active' : '' }}">
                    About
                </a>

                <div style="margin-top: auto; padding-top: 1rem; border-top: 1px solid rgba(0, 0, 128, 0.1);">
                    <a href="{{ path('app_logout') }}"
                       style="color: #dc2626; padding: 12px 20px; display: block; border-left: 4px solid transparent; border-radius: 0 8px 8px 0; transition: all 0.3s ease;">
                         Logout
                    </a>
                </div>
            </nav>
        </aside>

        <!-- Main Content -->
        <div class="main-content" id="main-content">
            <header>
                <h2 class="header-title">{% block header %}{% if is_granted('ROLE_ADMIN') %}Welcome, Admin{% else %}Welcome, Staff{% endif %}{% endblock %}</h2>
            </header>

            <main>
                {% block body %}{% endblock %}
            </main>

            <footer>
                &copy; {{ "now"|date("Y") }} Health Care System Admin. All Rights Reserved.
            </footer>
        </div>

    </body>
</html>
