<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Admin Panel{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚙️</text></svg>">

        {% block stylesheets %}
            {{ encore_entry_link_tags('app') }}
            <link rel="stylesheet" href="{{ asset('css/style.css') }}">
            <style>
                :root {
                    --primary-blue: #000080;
                    --accent-turquoise: #40E0D0;
                    --dark-navy: #03033f;
                    --white: #ffffff;
                    --text-dark: #2c3e50;
                    --light-gray: #f9f9f9;
                }

                * {
                    box-sizing: border-box;
                }

                body {
                    margin: 0;
                    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                    background: var(--light-gray);
                    color: var(--text-dark);
                    display: flex;
                    height: 100vh;
                    overflow: hidden;
                }

                /* Sidebar */
                .sidebar {
                    width: 260px;
                    background: var(--white);
                    color: var(--primary-blue);
                    display: flex;
                    flex-direction: column;
                    align-items: center;
                    padding: 1.2rem 0;
                    box-shadow: 4px 0 12px rgba(0,0,0,0.1);
                    transition: transform 0.3s ease;
                    position: relative;
                    overflow-y: auto;
                    scrollbar-width: none; /* Firefox */
                }

                .sidebar::-webkit-scrollbar {
                    display: none; /* Chrome, Safari */
                }

                .sidebar.hidden {
                    transform: translateX(-260px);
                }

                /* Logo + Brand */
                .sidebar .brand {
                    display: flex;
                    flex-direction: column;
                    align-items: center;
                    padding: 16px 16px 10px 16px;
                    width: 88%;
                    margin-top: -10px;
                    margin-bottom: 1.5rem;
                }

                .sidebar .brand .logo-container {
                    padding: 10px;
                    margin-bottom: 10px;
                    width: 100%;
                    display: flex;
                    justify-content: center;
                    align-items: center;
                }

                .sidebar .brand img {
                    width: 120px;
                    height: auto;
                    display: block;
                }

                .sidebar .brand h1 {
                    font-size: 1.2rem;
                    color: var(--primary-blue);
                    font-weight: 700;
                    margin: 0;
                    text-align: center;
                    letter-spacing: 0.5px;
                }

                /* Sidebar Navigation */
                .sidebar nav {
                    display: flex;
                    flex-direction: column;
                    width: 100%;
                    gap: 4px;
                    padding: 0 12px;
                }

                .sidebar nav a {
                    color: var(--primary-blue);
                    text-decoration: none;
                    padding: 12px 20px;
                    font-weight: 500;
                    font-size: 0.95rem;
                    border-left: 4px solid transparent;
                    border-radius: 0 8px 8px 0;
                    transition: all 0.3s ease;
                    display: block;
                }

                .sidebar nav a:hover {
                    background: rgba(0, 0, 128, 0.1);
                    border-left-color: var(--accent-turquoise);
                    padding-left: 28px;
                }

                .sidebar nav a.active {
                    background: rgba(0, 0, 128, 0.15);
                    border-left-color: var(--accent-turquoise);
                    font-weight: 600;
                    color: var(--primary-blue);
                }

                /* Main Content */
                .main-content {
                    flex: 1;
                    display: flex;
                    flex-direction: column;
                    min-height: 100vh;
                    transition: margin-left 0.3s ease;
                }

                .main-content.expanded {
                    margin-left: -260px;
                }

                /* Header */
                header {
                    background: linear-gradient(135deg, var(--accent-turquoise) 0%, var(--primary-blue) 100%);
                    color: var(--white);
                    padding: 1.2rem 2rem;
                    display: flex;
                    align-items: center;
                    justify-content: space-between;
                    box-shadow: 0 3px 12px rgba(0,0,0,0.12);
                    position: relative;
                    z-index: 100;
                }

                .header-title {
                    position: absolute;
                    left: 50%;
                    transform: translateX(-50%);
                    margin: 0;
                    font-size: 1.6rem;
                    font-weight: 700;
                    text-align: center;
                }

                .hamburger {
                    background: rgba(255, 255, 255, 0.15);
                    border: none;
                    color: var(--white);
                    font-size: 1.8rem;
                    cursor: pointer;
                    z-index: 10;
                    padding: 8px 12px;
                    border-radius: 8px;
                    transition: all 0.3s ease;
                }

                .hamburger:hover {
                    background: rgba(255, 255, 255, 0.25);
                    transform: scale(1.05);
                }

                main {
                    flex: 1;
                    padding: 2rem;
                    overflow-y: auto;
                    background: var(--light-gray);
                }

                footer {
                    background: var(--dark-navy);
                    color: var(--white);
                    text-align: center;
                    padding: 1.2rem;
                    font-size: 0.9rem;
                    margin-top: auto;
                    box-shadow: 0 -2px 8px rgba(0,0,0,0.1);
                }

                @media (max-width: 768px) {
                    .sidebar {
                        position: fixed;
                        height: 100%;
                        z-index: 1000;
                        transform: translateX(-260px);
                    }

                    .sidebar.show {
                        transform: translateX(0);
                    }

                    .main-content.expanded {
                        margin-left: 0;
                    }

                    .header-title {
                        font-size: 1.3rem;
                        position: static;
                        transform: none;
                    }
                }
            </style>
        {% endblock %}
    </head>

    <body>
        <!-- Sidebar -->
        <aside class="sidebar" id="sidebar">
            <div class="brand">
                <div class="logo-container">
                    <img src="{{ asset('images/backgroynd.png') }}" alt="Health Care Logo">
                </div>
                <h1>Admin Panel</h1>
            </div>

            <nav>
                <a href="{{ path('app_service_index') }}"
                   class="{{ app.request.attributes.get('_route') starts with 'app_dashboard' ? 'active' : '' }}">
                    Dashboard
                </a>

                <a href="{{ path('app_service_index') }}"
                   class="{{ app.request.attributes.get('_route') starts with 'app_service' ? 'active' : '' }}">
                    Manage Services
                </a>

                <a href="{{ path('app_doctor_index') }}"
                   class="{{ app.request.attributes.get('_route') starts with 'app_doctor' ? 'active' : '' }}">
                    Manage Doctors
                </a>

                <a href="{{ path('app_appointment_index') }}"
                   class="{{ app.request.attributes.get('_route') starts with 'app_appointment' ? 'active' : '' }}">
                    Appointments
                </a>

                <a href="#"
                   class="{{ app.request.attributes.get('_route') starts with 'app_report' ? 'active' : '' }}">
                    Reports
                </a>

                <a href="#"
                   class="{{ app.request.attributes.get('_route') starts with 'app_user' ? 'active' : '' }}">
                    Users
                </a>

                <a href="{{ path('app_about') }}"
                   class="{{ app.request.attributes.get('_route') starts with 'app_about' ? 'active' : '' }}">
                    About
                </a>
            </nav>
        </aside>

        <!-- Main Content -->
        <div class="main-content" id="main-content">
            <header>
                <button class="hamburger" id="toggle-btn">&#9776;</button>
                <h2 class="header-title">{% block header %}Welcome, Admin{% endblock %}</h2>
            </header>

            <main>
                {% block body %}{% endblock %}
            </main>

            <footer>
                &copy; {{ "now"|date("Y") }} Health Care System Admin. All Rights Reserved.
            </footer>
        </div>

        <script>
            const toggleBtn = document.getElementById('toggle-btn');
            const sidebar = document.getElementById('sidebar');
            const mainContent = document.getElementById('main-content');

            toggleBtn.addEventListener('click', () => {
                sidebar.classList.toggle('hidden');
                mainContent.classList.toggle('expanded');
                if (window.innerWidth <= 768) sidebar.classList.toggle('show');
            });
        </script>
    </body>
</html>
