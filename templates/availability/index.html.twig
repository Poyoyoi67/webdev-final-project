{% extends 'base.html.twig' %}

{% block title %}Doctor Schedule & Availability{% endblock %}

{% block body %}
    <style>
        :root {
            --primary-blue: #000080;
            --accent-turquoise: #40E0D0;
            --light-gray: #f8f9fa;
            --text-dark: #2c3e50;
        }

        h1 {
            text-align: center;
            margin-bottom: 1.5rem;
            font-weight: 700;
            background: linear-gradient(135deg, var(--primary-blue), var(--accent-turquoise));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .container-wrapper {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 2rem;
            margin-bottom: 2rem;
        }

        @media (max-width: 1024px) {
            .container-wrapper {
                grid-template-columns: 1fr;
            }
        }

        .card {
            background: white;
            padding: 1.5rem;
            border-radius: 12px;
            box-shadow: 0 8px 24px rgba(3, 3, 63, 0.12);
        }

        .card h2 {
            color: var(--primary-blue);
            margin-top: 0;
            margin-bottom: 1rem;
            font-size: 1.3rem;
        }

        .form-group {
            margin-bottom: 1rem;
        }

        .form-group label {
            display: block;
            margin-bottom: 0.5rem;
            color: var(--text-dark);
            font-weight: 500;
        }

        .form-group select,
        .form-group input[type="date"],
        .form-group input[type="checkbox"] {
            width: 100%;
            padding: 0.7rem;
            border: 1px solid #ddd;
            border-radius: 8px;
            font-size: 1rem;
        }

        .form-group input[type="checkbox"] {
            width: auto;
            margin-right: 0.5rem;
        }

        .checkbox-group {
            display: flex;
            align-items: center;
        }

        .btn {
            padding: 0.7rem 1.4rem;
            border: none;
            border-radius: 8px;
            font-weight: 500;
            cursor: pointer;
            font-size: 1rem;
            transition: all 0.3s ease;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary-blue), var(--accent-turquoise));
            color: white;
        }

        .btn-primary:hover {
            opacity: 0.9;
            transform: translateY(-2px);
        }

        .btn-secondary {
            background: #f8f9fa;
            color: var(--primary-blue);
            border: 1px solid var(--primary-blue);
        }

        .btn-secondary:hover {
            background: var(--accent-turquoise);
            color: white;
            border-color: var(--accent-turquoise);
        }

        table {
            width: 100%;
            border-collapse: collapse;
            background: white;
            box-shadow: 0 8px 24px rgba(3, 3, 63, 0.12);
            border-radius: 12px;
            overflow: hidden;
        }

        th, td {
            padding: 0.9rem;
            border-bottom: 1px solid var(--light-gray);
            text-align: left;
        }

        thead th {
            background: linear-gradient(135deg, var(--primary-blue), var(--accent-turquoise));
            color: white;
        }

        tbody tr:hover {
            background: rgba(64, 224, 208, 0.08);
        }

        .status {
            font-weight: 600;
        }

        .status.available { color: #16a34a; }
        .status.unavailable { color: #dc2626; }

        .actions form {
            display: inline-block;
        }

        .actions button {
            padding: 0.4rem 0.8rem;
            font-size: 0.9rem;
        }

        .flash-messages {
            margin-bottom: 1rem;
        }

        .alert {
            padding: 1rem;
            border-radius: 8px;
            margin-bottom: 0.5rem;
        }

        .alert-success {
            background: #d1fae5;
            color: #065f46;
            border-left: 4px solid #16a34a;
        }

        .alert-error {
            background: #fee2e2;
            color: #991b1b;
            border-left: 4px solid #dc2626;
        }
    </style>

    <h1>Doctor Schedule & Availability</h1>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <div class="alert alert-error">{{ message }}</div>
    {% endfor %}

    <div class="container-wrapper">
        <!-- Add Schedule Form -->
        <div class="card">
            <h2>Add Doctor Schedule</h2>
            <form action="{{ path('app_availability_add_schedule') }}" method="post">
                <div class="form-group">
                    <label for="doctor_id">Doctor</label>
                    <select name="doctor_id" id="doctor_id" required>
                        <option value="">Select a doctor</option>
                        {% for doctor in doctors %}
                            <option value="{{ doctor.id }}">{{ doctor.name }} - {{ doctor.specialization }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div class="form-group">
                    <label for="start_date">Start Date</label>
                    <input type="date" name="start_date" id="start_date" required value="{{ selectedDate|date('Y-m-d') }}">
                </div>

                <div class="form-group">
                    <label for="end_date">End Date (optional - leave same as start for single day)</label>
                    <input type="date" name="end_date" id="end_date" value="{{ selectedDate|date('Y-m-d') }}">
                </div>

                <div class="form-group">
                    <div class="checkbox-group">
                        <input type="checkbox" name="available" id="available" value="1" checked>
                        <label for="available">Available</label>
                    </div>
                    <small style="color: #6b7280; display: block; margin-top: 0.5rem;">
                        Uncheck to mark as unavailable for the selected date range
                    </small>
                </div>

                <button type="submit" class="btn btn-primary">Add Schedule</button>
            </form>
        </div>

        <!-- Quick Date Filter -->
        <div class="card">
            <h2>View Schedule</h2>
            <form method="get" action="{{ path('app_availability_index') }}">
                <div class="form-group">
                    <label for="view_date">Select Date to View</label>
                    <input type="date" name="date" id="view_date" value="{{ selectedDate|date('Y-m-d') }}" required>
                </div>
                <button type="submit" class="btn btn-secondary">Load Schedule</button>
            </form>
            <div style="margin-top: 1rem; padding-top: 1rem; border-top: 1px solid var(--light-gray);">
                <p style="margin: 0; color: var(--text-dark);">
                    <strong>Current View:</strong> {{ selectedDate|date('F d, Y') }}
                </p>
            </div>
        </div>
    </div>

    <table>
        <thead>
            <tr>
                <th>Doctor</th>
                <th>Specialization</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for doctor in doctors %}
            {% set availability = availabilityMap[doctor.id] ?? null %}
            {% set isAvailable = availability ? availability.available : false %}
            <tr>
                <td>{{ doctor.name }}</td>
                <td>{{ doctor.specialization }}</td>
                <td class="status {{ isAvailable ? 'available' : 'unavailable' }}">
                    {{ isAvailable ? '✅ Available' : '❌ Unavailable' }}
                </td>
                <td class="actions">
                    <form action="{{ path('app_availability_set') }}" method="post" style="display:inline;">
                        <input type="hidden" name="doctor_id" value="{{ doctor.id }}">
                        <input type="hidden" name="date" value="{{ selectedDate|date('Y-m-d') }}">
                        <input type="hidden" name="available" value="{{ isAvailable ? '0' : '1' }}">
                        <button type="submit" class="btn {{ isAvailable ? 'btn-secondary' : 'btn-primary' }}">
                            {{ isAvailable ? 'Mark Unavailable' : 'Mark Available' }}
                        </button>
                    </form>
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% endblock %}
