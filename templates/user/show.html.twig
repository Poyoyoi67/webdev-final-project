{% extends 'base.html.twig' %}

{% block title %}User Details{% endblock %}

{% block body %}
    <style>
        :root {
            --primary-blue: #000080;
            --accent-turquoise: #40E0D0;
        }

        h1 {
            text-align: center;
            margin-bottom: 1.5rem;
            font-weight: 700;
            background: linear-gradient(135deg, var(--primary-blue), var(--accent-turquoise));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .details-card {
            max-width: 600px;
            margin: 0 auto;
            background: white;
            padding: 2rem;
            border-radius: 12px;
            box-shadow: 0 8px 24px rgba(3, 3, 63, 0.12);
        }

        .details-table {
            width: 100%;
            border-collapse: collapse;
        }

        .details-table th {
            text-align: left;
            padding: 0.8rem;
            color: var(--primary-blue);
            font-weight: 600;
            width: 30%;
        }

        .details-table td {
            padding: 0.8rem;
            color: #2c3e50;
        }

        .actions {
            margin-top: 1.5rem;
            text-align: center;
        }

        .btn {
            display: inline-block;
            padding: 0.7rem 1.4rem;
            border-radius: 25px;
            font-weight: 500;
            text-decoration: none;
            margin: 0 0.5rem;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary-blue), var(--accent-turquoise));
            color: white;
        }

        .btn-secondary {
            color: var(--primary-blue);
            border: 2px solid var(--primary-blue);
        }
    </style>

    <h1>User Details</h1>

    <div class="details-card">
        <table class="details-table">
            <tr>
                <th>ID</th>
                <td>{{ user.id }}</td>
            </tr>
            <tr>
                <th>Email</th>
                <td>{{ user.email }}</td>
            </tr>
            <tr>
                <th>Roles</th>
                <td>{{ user.roles|join(', ') }}</td>
            </tr>
        </table>

        <div class="actions">
            <a href="{{ path('app_user_index') }}" class="btn btn-secondary">Back to List</a>
            <a href="{{ path('app_user_edit', {'id': user.id}) }}" class="btn btn-primary">Edit</a>
        </div>
    </div>
{% endblock %}

