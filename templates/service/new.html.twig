{% extends 'base.html.twig' %}

{% block title %}New Service{% endblock %}

{% block body %}
    <style>
        :root {
            --primary-blue: #000080;
            --accent-turquoise: #40E0D0;
            --dark-navy: #03033f;
            --light-gray: #f8f9fa;
            --medium-gray: #6c757d;
            --white: #ffffff;
            --text-dark: #2c3e50;
            --shadow-light: 0 2px 10px rgba(0, 0, 128, 0.1);
            --shadow-medium: 0 4px 20px rgba(0, 0, 128, 0.15);
            --shadow-strong: 0 8px 30px rgba(3, 3, 63, 0.2);
        }

        .form-container {
            max-width: 700px;
            margin: 3rem auto;
            background: var(--white);
            padding: 2rem 2.5rem;
            border-radius: 20px;
            box-shadow: var(--shadow-medium);
        }

        h1 {
            text-align: center;
            margin-bottom: 2rem;
            background: linear-gradient(135deg, var(--primary-blue), var(--accent-turquoise));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-weight: 700;
        }

        .form-group {
            margin-bottom: 1.5rem;
        }

        label {
            font-weight: 500;
            color: var(--primary-blue);
            display: block;
            margin-bottom: 0.5rem;
        }

        .form-input,
        .form-textarea {
            width: 100%;
            padding: 0.75rem 1rem;
            border: 2px solid var(--light-gray);
            border-radius: 10px;
            font-size: 1rem;
            transition: border 0.3s ease, box-shadow 0.3s ease;
        }

        .form-input:focus,
        .form-textarea:focus {
            border-color: var(--accent-turquoise);
            outline: none;
            box-shadow: 0 0 8px rgba(64, 224, 208, 0.4);
        }

        .form-textarea {
            min-height: 120px;
            resize: vertical;
        }

        .btn-submit {
            background: linear-gradient(135deg, var(--primary-blue), var(--dark-navy));
            color: var(--white);
            padding: 0.9rem 1.8rem;
            border: none;
            border-radius: 25px;
            font-size: 1rem;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: var(--shadow-light);
        }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-strong);
        }

        .btn-back {
            display: inline-block;
            margin-top: 1rem;
            color: var(--primary-blue);
            border: 2px solid var(--primary-blue);
            background: var(--white);
            padding: 0.6rem 1.2rem;
            border-radius: 20px;
            text-decoration: none;
            font-weight: 500;
            transition: all 0.3s ease;
        }

        .btn-back:hover {
            background: var(--accent-turquoise);
            color: var(--white);
            border-color: var(--accent-turquoise);
        }
    </style>

    <h1>Create a New Service</h1>

    <div class="form-container">
        {{ form_start(form) }}
            <div class="form-group">
                {{ form_label(form.name) }}
                {{ form_widget(form.name, {'attr': {'class': 'form-input'}}) }}
                {{ form_errors(form.name) }}
            </div>

            <div class="form-group">
                {{ form_label(form.price) }}
                {{ form_widget(form.price, {'attr': {'class': 'form-input'}}) }}
                {{ form_errors(form.price) }}
            </div>

            <div class="form-group">
                {{ form_label(form.doctor) }}
                {{ form_widget(form.doctor, {'attr': {'class': 'form-input'}}) }}
                {{ form_errors(form.doctor) }}
            </div>

            <div class="form-group">
                {{ form_label(form.text) }}
                {{ form_widget(form.text, {'attr': {'class': 'form-textarea'}}) }}
                {{ form_errors(form.text) }}
            </div>

            <div class="form-group">
                {{ form_label(form.duration) }}
                {{ form_widget(form.duration, {'attr': {'class': 'form-input'}}) }}
                {{ form_errors(form.duration) }}
            </div>

            <button type="submit" class="btn-submit">💾 Save Service</button>
        {{ form_end(form) }}
    </div>

    <p>
        <a href="{{ path('app_service_index') }}" class="btn-back">⬅ Back to list</a>
    </p>
{% endblock %}
