{% extends 'base.html.twig' %}

{% block title %}Appointment Details{% endblock %}

{% block body %}
    {% set can_manage = is_granted('ROLE_STAFF') or is_granted('ROLE_ADMIN') %}
    <style>
        :root {
            --primary-blue: #000080;
            --accent-turquoise: #40E0D0;
            --danger-red: #dc3545;
            --danger-red-dark: #a71d2a;
            --light-bg: #f8f9fa;
            --white: #ffffff;
            --text-dark: #2c3e50;
            --shadow-medium: 0 4px 20px rgba(0, 0, 128, 0.15);
        }

        h1 {
            text-align: center;
            margin: 2rem 0;
            font-weight: 700;
            background: linear-gradient(135deg, var(--primary-blue), var(--accent-turquoise));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .details-card {
            max-width: 700px;
            margin: 0 auto;
            background: var(--white);
            padding: 2rem;
            border-radius: 12px;
            box-shadow: var(--shadow-medium);
        }

        .details-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 2rem;
        }

        .details-table th {
            text-align: left;
            padding: 0.8rem;
            color: var(--primary-blue);
            font-weight: 600;
            background: var(--light-bg);
            border-bottom: 2px solid #ddd;
            width: 30%;
        }

        .details-table td {
            padding: 0.8rem;
            color: var(--text-dark);
            border-bottom: 1px solid #eee;
        }

        .page-actions {
            display: flex;
            justify-content: center;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .btn {
            display: inline-block;
            padding: 0.7rem 1.4rem;
            border-radius: 25px;
            font-weight: 500;
            text-decoration: none;
            transition: all 0.3s ease;
            text-align: center;
            min-width: 120px;
            cursor: pointer;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary-blue), var(--accent-turquoise));
            color: var(--white);
            border: none;
        }

        .btn-primary:hover {
            opacity: 0.9;
            transform: translateY(-2px);
        }

        .btn-secondary {
            color: var(--primary-blue);
            border: 2px solid var(--primary-blue);
            background: var(--white);
        }

        .btn-secondary:hover {
            background: var(--accent-turquoise);
            color: var(--white);
            border-color: var(--accent-turquoise);
            transform: translateY(-2px);
        }

        .btn-danger {
            background: linear-gradient(135deg, var(--danger-red), var(--danger-red-dark));
            color: var(--white);
            border: none;
        }

        .btn-danger:hover {
            opacity: 0.9;
            transform: translateY(-2px);
        }
    </style>

    <h1>Appointment Details</h1>

    <div class="details-card">
        <table class="details-table">
            <tbody>
                <tr>
                    <th>ID</th>
                    <td>{{ appointment.id }}</td>
                </tr>
                <tr>
                    <th>Patient Name</th>
                    <td>{{ appointment.patientName }}</td>
                </tr>
                <tr>
                    <th>Doctor</th>
                    <td>{{ appointment.doctor.name }}</td>
                </tr>
                <tr>
                    <th>Service</th>
                    <td>{{ appointment.service.name }}</td>
                </tr>
                <tr>
                    <th>Appointment Date</th>
                    <td>{{ appointment.appointmentDate|date('F d, Y - h:i A') }}</td>
                </tr>
                <tr>
                    <th>Status</th>
                    <td>
                        {% if appointment.status == 'confirmed' %}
                            ✅ Confirmed
                        {% elseif appointment.status == 'pending' %}
                            ⏳ Pending
                        {% elseif appointment.status == 'cancelled' %}
                            ❌ Cancelled
                        {% else %}
                            {{ appointment.status }}
                        {% endif %}
                    </td>
                </tr>
                <tr>
                    <th>Notes</th>
                    <td>{{ appointment.notes is defined and appointment.notes ? appointment.notes : 'No notes provided.' }}</td>
                </tr>
            </tbody>
        </table>

        <div class="page-actions">
            <a href="{{ path('app_appointment_index') }}" class="btn btn-secondary">⬅ Back to list</a>
            {% if can_manage and appointment.status == 'pending' %}
                <form method="post" action="{{ path('app_appointment_confirm', {id: appointment.id}) }}" style="display:inline;">
                    <input type="hidden" name="_token" value="{{ csrf_token('confirm' ~ appointment.id) }}">
                    <button type="submit" class="btn btn-primary">✓ Confirm</button>
                </form>
                <form method="post" action="{{ path('app_appointment_reject', {id: appointment.id}) }}" style="display:inline;">
                    <input type="hidden" name="_token" value="{{ csrf_token('reject' ~ appointment.id) }}">
                    <button type="submit" class="btn btn-danger">✗ Reject</button>
                </form>
            {% endif %}
            {% if can_manage %}
                <a href="{{ path('app_appointment_edit', {'id': appointment.id}) }}" class="btn btn-primary">✏ Edit</a>

                <form id="deleteForm" method="post"
                      action="{{ path('app_appointment_delete', {'id': appointment.id}) }}"
                      style="display:inline;">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ appointment.id) }}">
                    <button type="button" class="btn btn-danger" onclick="confirmDelete()">🗑 Delete</button>
                </form>
            {% endif %}
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        function confirmDelete() {
            Swal.fire({
                title: 'Are you sure?',
                text: "This appointment will be permanently deleted.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Yes, delete it!',
                cancelButtonText: 'Cancel',
                background: '#ffffff',
                customClass: {
                    title: 'text-lg font-bold text-[#000080]',
                    popup: 'rounded-xl shadow-lg',
                    confirmButton: 'px-4 py-2 rounded-full',
                    cancelButton: 'px-4 py-2 rounded-full'
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('deleteForm').submit();
                }
            })
        }
    </script>
{% endblock %}
