{% extends 'base.html.twig' %}

{% block title %}New Appointment{% endblock %}

{% block body %}
    <style>
        :root {
            --primary-blue: #000080;
            --accent-turquoise: #40E0D0;
            --dark-navy: #03033f;
            --light-gray: #f8f9fa;
            --medium-gray: #6c757d;
            --white: #ffffff;
            --shadow-light: 0 2px 10px rgba(0, 0, 128, 0.1);
            --shadow-strong: 0 8px 30px rgba(3, 3, 63, 0.2);
        }

        body {
            background-color: var(--light-gray);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: var(--dark-navy);
            padding: 30px;
        }

        h1 {
            text-align: center;
            font-weight: 700;
            font-size: 2rem;
            margin-bottom: 30px;
            background: linear-gradient(135deg, var(--primary-blue), var(--accent-turquoise));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        form {
            background-color: var(--white);
            max-width: 700px;
            margin: 0 auto;
            padding: 25px 35px;
            border-radius: 15px;
            box-shadow: var(--shadow-light);
        }

        label {
            display: block;
            font-weight: 600;
            color: var(--primary-blue);
            margin-bottom: 5px;
        }

        input[type="text"],
        input[type="datetime-local"],
        textarea,
        select {
            width: 100%;
            padding: 10px 12px;
            border: 1px solid #ddd;
            border-radius: 8px;
            margin-bottom: 20px;
            outline: none;
            transition: border-color 0.3s, box-shadow 0.3s;
        }

        input:focus,
        textarea:focus,
        select:focus {
            border-color: var(--accent-turquoise);
            box-shadow: 0 0 5px rgba(64, 224, 208, 0.4);
        }

        button {
            background: linear-gradient(135deg, var(--primary-blue), var(--accent-turquoise));
            color: var(--white);
            border: none;
            padding: 10px 25px;
            border-radius: 10px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.3s;
        }

        button:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-strong);
        }

        .actions {
            text-align: center;
            margin-top: 25px;
        }

        .back-link {
            display: inline-block;
            margin-top: 20px;
            text-decoration: none;
            color: var(--primary-blue);
            font-weight: 500;
            transition: color 0.3s;
        }

        .back-link:hover {
            color: var(--accent-turquoise);
        }
    </style>

    <h1>Create New Appointment</h1>

    <div class="form-container">
        {{ include('appointment/_form.html.twig') }}
    </div>

    <div class="actions">
        <a href="{{ path('app_appointment_index') }}" class="back-link">← Back to list</a>
    </div>
{% endblock %}
