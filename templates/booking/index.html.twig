{% extends 'base.html.twig' %}

{% block title %}Book Appointment{% endblock %}

{% block header %}Book an appointment{% endblock %}

{% block body %}
    <style>
        :root {
            --primary-blue: #000080;
            --accent-turquoise: #40E0D0;
            --dark-navy: #03033f;
            --light-gray: #f8f9fa;
            --white: #ffffff;
            --shadow-medium: 0 4px 20px rgba(0, 0, 128, 0.15);
        }

        .book-wrap { max-width: 720px; margin: 0 auto; }

        .book-intro {
            background: linear-gradient(135deg, rgba(0,0,128,0.04), rgba(64,224,208,0.08));
            border: 1px solid rgba(0,0,128,0.1);
            border-radius: 14px;
            padding: 1rem 1.2rem;
            margin-bottom: 1.5rem;
            font-size: 0.92rem;
            color: #475569;
            line-height: 1.5;
        }

        .form-container {
            background: var(--white);
            padding: 2rem 2.5rem;
            border-radius: 20px;
            box-shadow: var(--shadow-medium);
        }

        .form-group { margin-bottom: 1.4rem; }

        label {
            font-weight: 600;
            color: var(--primary-blue);
            display: block;
            margin-bottom: 0.45rem;
            font-size: 0.92rem;
        }

        .form-input, .form-select, .form-textarea {
            width: 100%;
            padding: 0.75rem 1rem;
            border: 2px solid var(--light-gray);
            border-radius: 10px;
            font-size: 1rem;
            font-family: inherit;
        }

        .form-input:focus, .form-select:focus, .form-textarea:focus {
            border-color: var(--accent-turquoise);
            outline: none;
            box-shadow: 0 0 8px rgba(64, 224, 208, 0.35);
        }

        .datetime-group {
            background: linear-gradient(135deg, rgba(0,0,128,0.03), rgba(64,224,208,0.07));
            border-left: 3px solid var(--accent-turquoise);
            border-radius: 12px;
            padding: 1rem 1.1rem;
        }

        .availability-note {
            font-size: 0.82rem;
            color: #64748b;
            margin-top: 0.35rem;
        }

        .availability-note strong { color: var(--primary-blue); }

        .btn-submit {
            background: linear-gradient(135deg, var(--primary-blue), var(--dark-navy));
            color: var(--white);
            padding: 0.9rem 1.8rem;
            border: none;
            border-radius: 25px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            width: 100%;
            margin-top: 0.5rem;
        }

        .btn-submit:hover { opacity: 0.92; transform: translateY(-1px); }

        .btn-link {
            display: inline-block;
            margin-top: 1rem;
            color: var(--primary-blue);
            text-decoration: none;
            font-weight: 500;
        }

        .alert {
            padding: 0.85rem 1rem;
            border-radius: 10px;
            margin-bottom: 1rem;
            font-size: 0.9rem;
        }
        .alert-success { background: #d1fae5; color: #065f46; }
        .alert-error { background: #fee2e2; color: #991b1b; }
    </style>

    <div class="book-wrap">
        <div class="book-intro">
            Choose a service, pick an <strong>available doctor</strong> for your visit date, then select date &amp; time.
            Your request stays <strong>pending</strong> until staff confirms or rejects it.
        </div>

        {% for message in app.flashes('success') %}
            <div class="alert alert-success">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="alert alert-error">{{ message }}</div>
        {% endfor %}

        <div class="form-container">
            {{ form_start(form, { attr: { id: 'booking-form', novalidate: 'novalidate' } }) }}

            <div class="form-group">
                {{ form_label(form.service) }}
                {{ form_widget(form.service, { attr: { class: 'form-select', id: 'booking-service' } }) }}
                {{ form_errors(form.service) }}
            </div>

            <div class="form-group datetime-group">
                {{ form_label(form.appointmentDate) }}
                {{ form_widget(form.appointmentDate, { attr: { class: 'form-input datetime-input', id: 'booking-datetime' } }) }}
                <p class="availability-note">Doctors shown below are available on the <strong>date</strong> you pick here.</p>
                {{ form_errors(form.appointmentDate) }}
            </div>

            <div class="form-group">
                {{ form_label(form.doctor) }}
                {{ form_widget(form.doctor, { attr: { class: 'form-select', id: 'booking-doctor' } }) }}
                <p class="availability-note" id="doctor-availability-msg">
                    {% if availableDoctorCount > 0 %}
                        {{ availableDoctorCount }} doctor(s) available for {{ selectedDate|date('M j, Y') }}.
                    {% else %}
                        No doctors marked available for {{ selectedDate|date('M j, Y') }}. Try another date.
                    {% endif %}
                </p>
                {{ form_errors(form.doctor) }}
            </div>

            <div class="form-group">
                {{ form_label(form.notes) }}
                {{ form_widget(form.notes) }}
                {{ form_errors(form.notes) }}
            </div>

            <button type="submit" class="btn-submit">Submit booking request</button>
            {{ form_end(form) }}
        </div>

        <a href="{{ path('app_book_my') }}" class="btn-link">View my booking requests →</a>
    </div>

    <script>
        (function () {
            const datetimeInput = document.getElementById('booking-datetime');
            const doctorSelect = document.getElementById('booking-doctor');
            const msgEl = document.getElementById('doctor-availability-msg');
            const doctorsUrl = '{{ path('app_book_available_doctors')|e('js') }}';

            if (!datetimeInput || !doctorSelect) return;

            function dateFromDatetime(value) {
                if (!value) return null;
                return value.split('T')[0];
            }

            function formatDateLabel(isoDate) {
                if (!isoDate) return '';
                const d = new Date(isoDate + 'T12:00:00');
                return d.toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' });
            }

            async function refreshDoctors() {
                const date = dateFromDatetime(datetimeInput.value);
                if (!date) return;

                const selected = doctorSelect.value;
                msgEl.textContent = 'Loading available doctors…';

                try {
                    const res = await fetch(doctorsUrl + '?date=' + encodeURIComponent(date));
                    const data = await res.json();
                    doctorSelect.innerHTML = '';

                    const placeholder = document.createElement('option');
                    placeholder.value = '';
                    placeholder.textContent = data.doctors.length
                        ? 'Choose an available doctor'
                        : 'No doctors available on this date';
                    doctorSelect.appendChild(placeholder);

                    data.doctors.forEach(function (doc) {
                        const opt = document.createElement('option');
                        opt.value = doc.id;
                        opt.textContent = doc.name + ' — ' + doc.specialization;
                        if (String(doc.id) === String(selected)) opt.selected = true;
                        doctorSelect.appendChild(opt);
                    });

                    msgEl.innerHTML = data.doctors.length
                        ? '<strong>' + data.doctors.length + '</strong> doctor(s) available for <strong>' + formatDateLabel(date) + '</strong>.'
                        : 'No doctors marked available for <strong>' + formatDateLabel(date) + '</strong>. Try another date.';
                } catch (e) {
                    msgEl.textContent = 'Could not load doctors. Please try again.';
                }
            }

            datetimeInput.addEventListener('change', refreshDoctors);
        })();
    </script>
{% endblock %}
