<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
</head>
<body style="font-family: Arial, Helvetica, sans-serif; font-size: 15px; line-height: 1.5; color: #111827;">
    <p style="margin: 0 0 12px;"><strong>Name:</strong> {{ name|e }}</p>
    <p style="margin: 0 0 12px;"><strong>Email:</strong> <a href="mailto:{{ contactEmail|e('html_attr') }}">{{ contactEmail|e }}</a></p>
    <p style="margin: 0 0 8px;"><strong>Message:</strong></p>
    <p style="margin: 0; white-space: pre-wrap;">{{ message|e }}</p>
</body>
</html>
