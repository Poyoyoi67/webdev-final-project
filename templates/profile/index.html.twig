{% extends 'base.html.twig' %}

{% block title %}My Profile{% endblock %}

{% block body %}
    <style>
        :root {
            --primary-blue: #000080;
            --accent-turquoise: #40E0D0;
            --light-gray: #f8f9fa;
            --text-dark: #2c3e50;
        }

        h1 {
            text-align: center;
            margin-bottom: 1.5rem;
            font-weight: 700;
            background: linear-gradient(135deg, var(--primary-blue), var(--accent-turquoise));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .profile-card {
            max-width: 800px;
            margin: 0 auto;
            background: white;
            padding: 1.5rem;
            border-radius: 12px;
            box-shadow: 0 8px 24px rgba(3, 3, 63, 0.12);
        }

        .avatar {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            object-fit: cover;
            border: 3px solid var(--accent-turquoise);
            box-shadow: 0 6px 18px rgba(3, 3, 63, 0.2);
        }

        .form-group {
            margin-bottom: 1rem;
        }

        label {
            display: block;
            margin-bottom: 0.4rem;
            color: var(--text-dark);
            font-weight: 500;
        }

        input, .form-control {
            width: 100%;
            padding: 0.75rem;
            border: 1px solid #e5e7eb;
            border-radius: 10px;
            font-size: 1rem;
        }

        button {
            padding: 0.8rem 1.4rem;
            border: none;
            border-radius: 10px;
            background: linear-gradient(135deg, var(--primary-blue), var(--accent-turquoise));
            color: white;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        button:hover {
            opacity: 0.9;
            transform: translateY(-1px);
        }

        .flash {
            padding: 0.9rem 1rem;
            border-radius: 10px;
            margin-bottom: 0.8rem;
        }

        .flash-success { background: #d1fae5; color: #065f46; border-left: 4px solid #16a34a; }
        .flash-error { background: #fee2e2; color: #991b1b; border-left: 4px solid #dc2626; }
    </style>

    <h1>My Profile</h1>

    {% for message in app.flashes('success') %}
        <div class="flash flash-success">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="flash flash-error">{{ message }}</div>
    {% endfor %}

    <div class="profile-card">
        <div style="display:flex; align-items:center; gap:1rem; margin-bottom:1.2rem;">
            <img class="avatar" src="{{ user.profilePicture ?: asset('images/backgroynd.png') }}" alt="Avatar">
            <div>
                <div style="font-weight:700; color:var(--primary-blue); font-size:1.2rem;">{{ user.username }}</div>
                <div style="color:#6b7280; font-size:0.95rem;">Roles: {{ user.roles|join(', ') }}</div>
            </div>
        </div>

        {{ form_start(form, {'attr': {'enctype': 'multipart/form-data'}}) }}
            <div class="form-group">
                {{ form_label(form.username) }}
                {{ form_widget(form.username) }}
                {{ form_errors(form.username) }}
            </div>

            <div class="form-group">
                {{ form_label(form.profilePicture) }}
                {{ form_widget(form.profilePicture) }}
                {{ form_errors(form.profilePicture) }}
            </div>

            <div class="form-group">
                {{ form_label(form.plainPassword) }}
                {{ form_widget(form.plainPassword) }}
                {{ form_errors(form.plainPassword) }}
            </div>

            <button type="submit">Save Changes</button>
        {{ form_end(form) }}
    </div>
{% endblock %}

