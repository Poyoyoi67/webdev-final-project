<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Clinic Login</title>
    <style>
        :root {
            --primary: #0f3c74;
            --primary-dark: #0b2a52;
            --accent: #24b8b5;
            --bg: #eef4fb;
            --text: #1f2937;
            --muted: #6b7280;
            --border: #d4e1f0;
        }

        * { box-sizing: border-box; }

        body {
            margin: 0;
            font-family: 'Segoe UI', Tahoma, sans-serif;
            background: var(--bg);
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            padding: 20px;
        }

        .layout {
            width: min(920px, 100%);
            display: grid;
            grid-template-columns: 1.05fr 1fr;
            border-radius: 18px;
            overflow: hidden;
            box-shadow: 0 20px 42px rgba(15, 60, 116, 0.18);
            background: #fff;
        }

        .aside {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: #e8f2ff;
            padding: 38px 30px;
        }

        .aside h1 {
            margin: 0 0 10px;
            font-size: 1.9rem;
        }

        .aside p {
            margin: 0;
            color: #d6e5fb;
            line-height: 1.6;
        }

        .checks {
            margin-top: 24px;
            padding-left: 18px;
        }

        .checks li {
            margin-bottom: 8px;
            color: #d9ebff;
        }

        .card {
            padding: 36px;
        }

        h2 {
            margin: 0 0 8px;
            color: var(--primary);
            font-size: 1.6rem;
        }

        p.subtitle {
            margin: 0 0 22px;
            color: var(--muted);
        }

        label { display: block; margin-bottom: 6px; color: var(--text); font-weight: 600; }

        input {
            width: 100%;
            padding: 12px 13px;
            border-radius: 10px;
            border: 1px solid var(--border);
            font-size: 15px;
        }

        input:focus {
            outline: 2px solid rgba(36, 184, 181, 0.5);
            border-color: transparent;
        }

        .form-group { margin-bottom: 16px; }

        button {
            width: 100%;
            padding: 12px;
            border: none;
            border-radius: 10px;
            background: linear-gradient(135deg, var(--primary), var(--accent));
            color: #fff;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: transform 0.2s ease;
        }

        button:hover { transform: translateY(-1px); }

        .link-row { margin-top: 12px; text-align: center; }

        .link-row a { color: var(--primary); text-decoration: none; font-weight: 600; }

        .oauth-divider {
            text-align: center;
            margin: 16px 0 12px;
            color: var(--muted);
            font-size: 0.9rem;
        }

        .oauth-btn {
            width: 100%;
            display: inline-flex;
            justify-content: center;
            align-items: center;
            gap: 8px;
            padding: 12px;
            border-radius: 10px;
            text-decoration: none;
            border: 1px solid #d1d5db;
            color: #111827;
            background: #fff;
            font-weight: 600;
            transition: background-color 0.2s ease;
        }

        .oauth-btn:hover {
            background: #f9fafb;
        }

        .error {
            background: #ffe2e2;
            padding: 10px 12px;
            color: #b91c1c;
            border-left: 4px solid #ef4444;
            border-radius: 8px;
            margin-bottom: 14px;
        }

        @media (max-width: 800px) {
            .layout {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
<div class="layout">
    <aside class="aside">
        <h1>Clinic Portal</h1>
        <p>Secure access for patients and staff to appointments, schedules, and healthcare records.</p>
        <ul class="checks">
            <li>Trusted and secure sign in</li>
            <li>Professional clinic workflow</li>
            <li>Fast access to your account</li>
        </ul>
    </aside>
    <div class="card">
    <h2>Welcome Back</h2>
    <p class="subtitle">Please sign in to continue.</p>

    {% for message in app.flashes('success') %}
        <div class="error" style="background: #e9fff6; color: #065f46; border-left-color: #10b981;">
            {{ message }}
        </div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="error">
            {{ message }}
        </div>
    {% endfor %}

    {% if app.request.query.get('registerFirst') %}
        <div class="error" style="background: #fff5cc; color: #8a6a00; border-left-color: #f2c94c;">
            You need an account to access that page. Please register first if you are new.
        </div>
    {% endif %}

    {% if error %}
        <div class="error">
            {{ error.messageKey|trans(error.messageData, 'security') }}
        </div>
    {% endif %}

    <form method="post">
        <div class="form-group">
            <label for="inputEmail">Email</label>
            <input type="email" value="{{ last_username }}" name="email" id="inputEmail" required autofocus>
        </div>

        <div class="form-group">
            <label for="inputPassword">Password</label>
            <input type="password" name="password" id="inputPassword" required>
        </div>

        <input type="hidden" name="csrf_token" value="{{ csrf_token('authenticate') }}">
        <button type="submit">Sign in</button>
    </form>

    <div class="oauth-divider">or</div>
    <a href="{{ path('connect_google') }}" class="oauth-btn">
        <i class="fab fa-google"></i>
        Login with Google
    </a>

    <div class="link-row">
        New here? <a href="{{ path('app_register') }}">Create an account</a>
    </div>
    </div>
</div>
</body>
</html>
