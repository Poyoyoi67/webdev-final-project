# Copy to .env.local for local development (never commit .env.local).
# On Railway, set these in the service Variables tab (not in git).

###> symfony/framework-bundle ###
APP_ENV=prod
APP_DEBUG=0
APP_SECRET=change_me_to_a_long_random_string
###< symfony/framework-bundle ###

# Public URL of your Railway service (used for links/emails). Example:
# DEFAULT_URI=https://your-app.up.railway.app

###> doctrine/doctrine-bundle ###
# Local Docker MySQL:
# DATABASE_URL="mysql://test_demo_user:test_demo_password@127.0.0.1:3308/test_demo_db?serverVersion=8.0.32&charset=utf8mb4"
# Railway: use variable reference ${{MySQL.MYSQL_URL}} or paste MySQL URL from Railway
DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/DATABASE?serverVersion=8.0.32&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> nelmio/cors-bundle ###
# Allow web + mobile API clients (tighten in production if needed)
CORS_ALLOW_ORIGIN='^https?://.*$'
###< nelmio/cors-bundle ###

###> lexik/jwt-authentication-bundle ###
# PEM files are generated at container start on Railway (see scripts/railway-start.sh)
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=change_me_to_a_long_random_passphrase
###< lexik/jwt-authentication-bundle ###

###> knpuniversity/oauth2-client-bundle ###
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
###< knpuniversity/oauth2-client-bundle ###

MAILER_FROM_ADDRESS=
MAILER_FROM_NAME="Health Care Clinic"
CONTACT_NOTIFY_EMAIL=

###> symfony/brevo-mailer ###
MAILER_DSN=
###< symfony/brevo-mailer ###
